{
  "name": "ai-organiser",
  "version": "1.0.15",
  "description": "Automatically analyze note content and add relevant tags using AI (with Chinese interface support)",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run test:all && node esbuild.config.mjs production",
    "build:quick": "npx tsc -p tsconfig.build.json -noEmit && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:auto": "node scripts/automated-tests.js",
    "test:all": "npx tsc -p tsconfig.build.json -noEmit && vitest run && node scripts/automated-tests.js",
    "precommit": "npm run test:all",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "install-ffmpeg": "node scripts/install-ffmpeg.js"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "ai",
    "tags",
    "chinese",
    "internationalization"
  ],
  "author": "L Strydom",
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.0",
    "happy-dom": "^20.6.1",
    "obsidian": "latest",
    "tslib": "^2.8.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "docx": "^9.5.1",
    "dom-to-pptx": "^1.1.5",
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.0",
    "jspdf": "^4.0.0",
    "officeparser": "^6.0.4",
    "openai": "^6.33.0",
    "perfect-freehand": "^1.2.3",
    "pptxgenjs": "^4.0.1",
    "voy-search": "^0.6.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  }
}
