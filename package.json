{
  "name": "ai-organiser",
  "version": "1.0.15",
  "description": "Automatically analyze note content and add relevant tags using AI (with Chinese interface support)",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npx tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:auto": "node tests/automated-tests.js",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "install-ffmpeg": "node scripts/install-ffmpeg.js"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "ai",
    "tags",
    "chinese",
    "internationalization"
  ],
  "author": "Nie Hu",
  "license": "MIT",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.0",
    "@types/uuid": "^10.0.0",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.0",
    "obsidian": "latest",
    "tslib": "^2.8.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "js-yaml": "^4.1.0",
    "officeparser": "^6.0.4",
    "uuid": "^13.0.0",
    "voy-search": "^0.6.0"
  }
}
