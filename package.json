{
  "name": "ai-organiser",
  "version": "1.0.16",
  "description": "Automatically analyze note content and add relevant tags using AI (with Chinese interface support)",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run test:all && node esbuild.config.mjs production",
    "build:quick": "npx tsc -p tsconfig.build.json -noEmit && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:auto": "node scripts/automated-tests.js",
    "test:all": "npx tsc -p tsconfig.build.json -noEmit && vitest run && node scripts/automated-tests.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "precommit": "npm run lint && npm run test:all",
    "persona:smoke": "node scripts/persona-harness/smoke.mjs",
    "persona:deploy": "node scripts/persona-harness/deploy.mjs",
    "persona:inspect": "node scripts/persona-harness/inspect-commands.mjs",
    "persona:entry-points": "node scripts/persona-harness/inspect-entry-points.mjs",
    "persona:register": "node scripts/persona-harness/register-personas.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "install-ffmpeg": "node scripts/install-ffmpeg.js"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "ai",
    "tags",
    "chinese",
    "internationalization"
  ],
  "author": "L Strydom",
  "license": "MIT",
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@eslint/json": "^1.2.0",
    "@google/genai": "^1.50.1",
    "@playwright/test": "^1.59.1",
    "@supabase/supabase-js": "^2.103.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.0.18",
    "builtin-modules": "^5.0.0",
    "codeowners-utils": "^1.0.2",
    "esbuild": "^0.27.0",
    "eslint": "^10.2.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "happy-dom": "^20.6.1",
    "micromatch": "^4.0.8",
    "obsidian": "latest",
    "proper-lockfile": "^4.1.2",
    "tslib": "^2.8.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@mozilla/readability": "^0.6.0",
    "docx": "^9.5.1",
    "dom-to-pptx": "^1.1.5",
    "dotenv": "^17.3.1",
    "js-yaml": "^4.1.0",
    "jspdf": "^4.0.0",
    "officeparser": "^6.0.4",
    "openai": "^6.33.0",
    "perfect-freehand": "^1.2.3",
    "pptxgenjs": "^4.0.1",
    "voy-search": "^0.6.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  }
}
